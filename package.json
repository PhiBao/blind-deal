{
	"name": "blinddeal",
	"version": "0.1.0",
	"description": "Confidential P2P price negotiation on Fhenix using FHE",
	"scripts": {
		"test": "REPORT_GAS=true hardhat test",
		"clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json ./deployments/localcofhe",
		"compile": "hardhat compile",
		"-----": "",
		" --- blinddeal (arb-sepolia) ---": "",
		"  -----": "",
		"arb-sepolia:deploy-blinddeal": "hardhat deploy-blinddeal --network arb-sepolia",
		"arb-sepolia:create-deal": "hardhat create-deal --network arb-sepolia",
		"arb-sepolia:submit-price": "hardhat submit-price --network arb-sepolia",
		"arb-sepolia:finalize-deal": "hardhat finalize-deal --network arb-sepolia",
		"------": "",
		" --- blinddeal (eth-sepolia) ---": "",
		"  ------": "",
		"eth-sepolia:deploy-blinddeal": "hardhat deploy-blinddeal --network eth-sepolia",
		"eth-sepolia:create-deal": "hardhat create-deal --network eth-sepolia",
		"eth-sepolia:submit-price": "hardhat submit-price --network eth-sepolia",
		"eth-sepolia:finalize-deal": "hardhat finalize-deal --network eth-sepolia"
	},
	"author": "",
	"license": "MIT",
