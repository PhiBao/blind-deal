# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# Deployer / hot-wallet private key (for contract deployment + escrow API)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs (public defaults are used if not set)
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Frontend RPC URLs (Vite requires VITE_ prefix to expose to client)
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
VITE_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Etherscan API key (works for Etherscan + Arbiscan + all Etherscan-family explorers)
ETHERSCAN_API_KEY=

# Telegram Bot (Wave 3)
TELEGRAM_BOT_TOKEN=
FRONTEND_URL=https://blind-deal.vercel.app
